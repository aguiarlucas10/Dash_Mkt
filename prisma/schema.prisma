// Dashboard de Criativos — schema Prisma
// Domínio: organização de demanda de criativos para anúncios + rastreamento
// de rupturas de estoque e anúncios pausados por essa razão.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Em Prisma 7 a connection string vai em prisma.config.ts (CLI) e via
  // adapter no construtor do PrismaClient (runtime). Ver src/lib/db.ts.
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum Tier {
  A
  B
  C
}

enum TaskType {
  LAUNCH
  PROMO
  EVERGREEN
  REPLACEMENT
}

enum Priority {
  P0
  P1
  P2
  P3
}

enum TaskStatus {
  BACKLOG
  BRIEFING
  IN_PRODUCTION
  IN_REVIEW
  APPROVED
  PUBLISHED
}

enum Platform {
  META
  TIKTOK
  GOOGLE
  YOUTUBE
}

enum AdStatus {
  ACTIVE
  PAUSED
}

enum PauseReason {
  STOCKOUT
  LOW_PERFORMANCE
  MANUAL
  CREATIVE_REVIEW
}

// ─── Models ────────────────────────────────────────────────────────────────

// User espelha o auth.users do Supabase. O id é exatamente o uuid de auth.users,
// para que possamos consultar nossa allowlist apenas com o id da sessão.
// Quem não tem linha aqui, não tem acesso (allowlist no nível da aplicação).
model User {
  id        String   @id @db.Uuid
  email     String   @unique
  name      String?
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasksRequested CreativeTask[] @relation("RequestedBy")
  tasksAssigned  CreativeTask[] @relation("AssignedTo")
  statusChanges  StatusChange[]
}

// DORMANT: mantido para futura integração com Shopify/Bling. Sem UI no app
// atualmente. Não criar referências novas — preferir o campo `subject` em
// CreativeTask e o model StockoutItem para rupturas.
model Product {
  id           String   @id @default(cuid())
  sku          String   @unique
  name         String
  margin       Decimal? @db.Decimal(6, 4)
  priorityTier Tier?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creativeTasks CreativeTask[]
  ads           Ad[]
  stockouts     StockoutEvent[]
}

model CreativeTask {
  id              String     @id @default(cuid())
  title           String
  // subject: texto livre — produto, categoria, coleção, campanha. Ex: "Brincos
  // Q3", "Coleção Verão 2026", "Brinco Solitário Ouro". Não é FK para Product
  // porque a unidade de planejamento criativo nem sempre é um SKU.
  subject         String?
  description     String?
  // creativeCount: quantos criativos a task entrega (1, 5, 10…). Usado para
  // somar contra a meta mensal — uma task pode representar várias entregas.
  creativeCount   Int        @default(1)
  // goalCategoryId: a qual meta esta task contribui (ex: "Criativos de mídia",
  // "Ativações Studio"). Opcional — tasks sem categoria ainda contam no total
  // mas não em nenhuma meta específica.
  goalCategoryId  String?
  goalCategory    GoalCategory? @relation(fields: [goalCategoryId], references: [id], onDelete: SetNull)
  type            TaskType
  priority        Priority   @default(P2)
  deadline        DateTime?
  status          TaskStatus @default(BACKLOG)
  platformTargets Platform[]
  assets          String[]   @default([])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  productId     String?
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  requestedById String   @db.Uuid
  requestedBy   User     @relation("RequestedBy", fields: [requestedById], references: [id])
  assignedToId  String?  @db.Uuid
  assignedTo    User?    @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  statusHistory StatusChange[]
  ads           AdCreative[]

  @@index([status])
  @@index([productId])
  @@index([assignedToId])
  @@index([deadline])
}

model StatusChange {
  id         String      @id @default(cuid())
  taskId     String
  task       CreativeTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fromStatus TaskStatus?
  toStatus   TaskStatus
  userId     String      @db.Uuid
  user       User        @relation(fields: [userId], references: [id])
  at         DateTime    @default(now())

  @@index([taskId])
  @@index([at])
}

// DORMANT: integração com Meta Ads / Google Ads chega na Fase 3.
model Ad {
  id          String       @id @default(cuid())
  externalId  String?
  name        String
  platform    Platform
  status      AdStatus     @default(ACTIVE)
  pauseReason PauseReason?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  productId  String?
  product    Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  stockoutId String?
  stockout   StockoutEvent? @relation(fields: [stockoutId], references: [id], onDelete: SetNull)

  creatives AdCreative[]

  @@index([status])
  @@index([productId])
  @@index([stockoutId])
}

// DORMANT: histórico de quais criativos rodaram em quais anúncios. Útil quando
// integrarmos com Meta Ads na Fase 3.
model AdCreative {
  id        String       @id @default(cuid())
  adId      String
  ad        Ad           @relation(fields: [adId], references: [id], onDelete: Cascade)
  taskId    String
  task      CreativeTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  startedAt DateTime     @default(now())
  endedAt   DateTime?

  @@index([adId])
  @@index([taskId])
}

// DORMANT: ruptura com data de início/fim e vínculo com anúncios afetados.
// Substituído pela tabela plana StockoutItem para a UI atual.
model StockoutEvent {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  startedAt DateTime
  endedAt   DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  affectedAds Ad[]

  @@index([productId])
  @@index([endedAt])
}

// ─── Novos models (iteração Calendário/Metas/Rupturas-flat) ────────────────

// GoalCategory: tipo de meta (ex: "Criativos de mídia", "Ativações com
// Influenciadores no Studio"). O admin cria as categorias; cada task escolhe
// uma. Cada categoria tem uma meta mensal (target) separada via `Goal`.
model GoalCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String?  // hex opcional para UI (chip/card)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goals Goal[]
  tasks CreativeTask[]
}

// Meta mensal de uma categoria. Uma linha por (categoria, mês). O admin define
// o target; o sistema calcula realizado vs em aberto a partir das CreativeTask
// com `goalCategoryId` igual e `deadline` no mês.
model Goal {
  id         String   @id @default(cuid())
  categoryId String
  category   GoalCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  month      DateTime @db.Date
  target     Int
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([categoryId, month])
}

// Ruptura simplificada — tabela plana. Cada item é um produto/categoria que
// está ou esteve em ruptura. Status é só ACTIVE/INACTIVE; sem datas, sem
// vínculo com anúncios. Para visão mais rica, ver StockoutEvent (dormante).
model StockoutItem {
  id        String             @id @default(cuid())
  product   String
  category  String?
  status    StockoutItemStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([status])
}

enum StockoutItemStatus {
  ACTIVE
  INACTIVE
}
