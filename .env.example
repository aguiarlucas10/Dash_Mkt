# Supabase Postgres. Em "Project Settings > Database > Connection string":
#   - DATABASE_URL: Transaction pooler (porta 6543), com ?pgbouncer=true&connection_limit=1
#   - DIRECT_URL: Session pooler (porta 5432 no mesmo host do pooler). É IPv4
#     e funciona em qualquer rede; é o que prisma migrate usa.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Supabase Auth — "Project Settings > API". A anon key é pública (vai no bundle).
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Service role key — "Project Settings > API > service_role (secret)". NÃO é
# público, NUNCA usar no client. Necessária para criar/remover usuários via
# /admin/users (chamadas a auth.admin.createUser / deleteUser).
SUPABASE_SERVICE_ROLE_KEY=""
